{
    "compilerOptions": {
        /* cypress enables deprecated downlevelIteration */
        "ignoreDeprecations": "6.0",

        "rootDir": "..",
        "target": "es6",
        "lib": ["es6", "dom"],
        "moduleResolution": "bundler",
        "types": ["cypress", "node"]
    },
    "include": ["**/*.ts"]
}
