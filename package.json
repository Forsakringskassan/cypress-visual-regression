{
  "name": "@forsakringskassan/cypress-visual-regression",
  "version": "4.0.0",
  "description": "Module for adding visual regression testing to Cypress",
  "keywords": [
    "visual regression",
    "image diff",
    "cypress"
  ],
  "homepage": "https://github.com/Forsakringskassan/cypress-visual-regression",
  "bugs": "https://github.com/Forsakringskassan/cypress-visual-regression/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/cypress-visual-regression.git"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "files": [
    "dist",
    "commands.js",
    "commands.d.ts",
    "plugin.js",
    "plugin.d.ts"
  ],
  "scripts": {
    "build": "run-s build:*",
    "build:dts": "dts-bundle-generator --no-check -o dist/commands.d.ts src/commands.d.ts && dts-bundle-generator --no-check -o dist/plugin.d.ts src/plugin.d.ts",
    "build:esbuild": "esbuild --bundle --platform=node --target=node22 --outdir=dist src/commands.js src/plugin.js",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "lint": "npm run eslint",
    "prepack": "release-prepack --bundle",
    "postpack": "release-postpack",
    "prepublishOnly": "release-prepublish --bundle",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "postpublish": "release-postpublish",
    "pretest": "run-s prettier:check eslint",
    "test": "jest"
  },
  "commitlint": {
    "extends": [
      "@forsakringskassan/commitlint-config/no-jira"
    ]
  },
  "lint-staged": {
    "*.{js,json,md,ts}": "prettier --write",
    "*.{js,ts}": "eslint --fix"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-config"
  },
  "jest": {
    "preset": "@forsakringskassan/jest-config"
  },
  "dependencies": {
    "pngjs": "7.0.0"
  },
  "devDependencies": {
    "@forsakringskassan/commitlint-config": "3.6.4",
    "@forsakringskassan/eslint-config": "14.2.0",
    "@forsakringskassan/eslint-config-jest": "14.2.0",
    "@forsakringskassan/eslint-config-typescript": "14.2.1",
    "@forsakringskassan/jest-config": "30.3.2",
    "@forsakringskassan/prettier-config": "3.5.0",
    "@html-validate/release-scripts": "7.2.3",
    "@tsconfig/node22": "22.0.5",
    "@tsconfig/recommended": "1.0.13",
    "@tsconfig/strictest": "2.0.8",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.19",
    "cypress": "15.15.0",
    "dts-bundle-generator": "9.5.1",
    "esbuild": "0.28.0",
    "npm-pkg-lint": "5.1.0",
    "npm-run-all2": "9.0.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "cypress": "^12.0.0 || ^13.0.0 || ^14.0.0 || ^15.0.0"
  },
  "engines": {
    "node": "^22.16 || >= 24"
  }
}
